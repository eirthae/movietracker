# Copy to .env and fill in. Both values are client-safe (publishable).
# Find them in Supabase Dashboard → Project Settings → API.
# With no .env the app runs on bundled mock data (also forced by ?mock in the URL).
VITE_SUPABASE_URL=https://<your-project-ref>.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxxxxxxxxxxxxxxxxxxxxxxx
